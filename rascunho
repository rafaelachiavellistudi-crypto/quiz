                yes: ["rock"],
                no: ["classic"]
            },

            {
                question: "Você gosta de músicas instrumentais?",
                yes: ["classic", "chill"],
                no: ["pop"]
            },

            {
                question: "Você prefere músicas com letras reflexivas?",
                yes: ["indie"],
                no: ["pop"]
            },

            {
                question: "Você gosta de batidas eletrônicas?",
                yes: ["pop"],
                no: ["classic"]
            },

            {
                question: "Você gosta de sons mais pesados?",
                yes: ["rock"],
                no: ["chill"]
            },

            {
                question: "Você gosta de músicas para estudar?",
                yes: ["chill"],
                no: ["rock"]
            },

            {
                question: "Você prefere músicas antigas?",
                yes: ["classic", "rock"],
                no: ["pop"]
            },

            {
                question: "Você gosta de refrões chiclete?",
                yes: ["pop"],
                no: ["indie"]
            },

            {
                question: "Você gosta de bandas alternativas?",
                yes: ["indie"],
                no: ["pop"]
            },

            {
                question: "Você gosta de piano e violino?",
                yes: ["classic"],
                no: ["rock"]
            },

            {
                question: "Você gosta de músicas para dormir?",
                yes: ["chill"],
                no: ["rock"]
            },

            {
                question: "Você gosta de festivais e shows grandes?",
                yes: ["pop", "rock"],
                no: ["classic"]
            },

            {
                question: "Você prefere músicas suaves?",
                yes: ["chill", "classic"],
                no: ["rock"]
            },

            {
                question: "Você gosta de músicas com muita energia?",
                yes: ["rock", "pop"],
                no: ["classic"]
            },

            {
                question: "Você gosta de músicas mais criativas e diferentes?",
                yes: ["indie"],
                no: ["pop"]
            },

            {
                question: "Você gosta de músicas com orquestra?",
                yes: ["classic"],
                no: ["rock"]
            },

