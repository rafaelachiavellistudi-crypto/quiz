                yes: ["classic", "chill"],
                no: ["rock"]
            },

            {
                question: "Você gosta de músicas emocionais e lentas?",
                yes: ["indie", "classic"],
                no: ["pop"]
            },

            {
                question: "Você gosta de músicas para animar o dia?",
                yes: ["pop"],
