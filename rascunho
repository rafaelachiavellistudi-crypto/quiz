            },

            {
                question: "Você gosta de músicas profundas?",
                yes: ["indie"],
                no: ["pop"]
            },

            {
                question: "Você gosta de músicas relaxantes sem letra?",
                yes: ["chill", "classic"],
                no: ["rock"]
            },

            {
                question: "Você gosta de músicas com muita bateria?",
                yes: ["rock"],
                no: ["classic"]
            },

            {
                question: "Você gosta de música com mistura de estilos?",
                yes: ["indie", "pop"],
                no: ["classic"]
            },

            {
                question: "Você gosta de músicas que causam forte emoção?",
                yes: ["classic", "indie"],
                no: ["pop"]
            }

        ];

        let currentQuestion = 0;

        const questionElement = document.getElementById("question");

        questionElement.innerText = questions[currentQuestion].question;

        function answer(isYes) {

            const current = questions[currentQuestion];

            if(isYes) {

                current.yes.forEach(style => {
                    styles[style]++;
                });

            } else {

                current.no.forEach(style => {
                    styles[style]++;
                });
            }

            currentQuestion++;

            if(currentQuestion < 10) {

                questionElement.innerText =
                questions[currentQuestion].question;

                document.getElementById("counter").innerText =
                (currentQuestion + 1) + " / " + questions.length;

            } else {

                showResult();
            }
        }

        function showResult() {

            const result = document.getElementById("result");

            questionElement.style.display = "none";

            document.getElementById("counter").style.display = "none";

            document.querySelector(".buttons").style.display = "none";

            const winner = Object.keys(styles).reduce((a, b) =>
                styles[a] > styles[b] ? a : b
            );

            if(winner === "pop") {

                result.innerText =
                "🎧 Seu estilo combina com POP! Você gosta de músicas modernas, animadas, populares e cheias de energia.";

            } else if(winner === "rock") {

                result.innerText =
                "🎸 Seu estilo combina com ROCK! Você gosta de intensidade, guitarras marcantes e músicas com muita presença.";

            } else if(winner === "indie") {

                result.innerText =
                "🎵 Seu estilo combina com INDIE! Você prefere músicas criativas, emocionais e com personalidade própria.";

            } else if(winner === "chill") {

                result.innerText =
                "🎹 Seu estilo combina com LO-FI e CHILL! Você gosta de ambientes tranquilos, relaxamento e músicas suaves.";

            } else {

                result.innerText =
                "🎻 Seu estilo combina com MÚSICA CLÁSSICA! Você aprecia melodias emocionantes, instrumentos clássicos e músicas profundas.";
            }
        }

        function resetQuiz() {

            const container =
            document.querySelector(".question-container");

            container.classList.add("fade");

            setTimeout(() => {

                currentQuestion = 0;

                for(let style in styles) {
                    styles[style] = 0;
                }

                questionElement.style.display = "block";

                questionElement.innerText =
                questions[currentQuestion].question;

                const counterElement =
                document.getElementById("counter");

                counterElement.style.display = "block";

                counterElement.innerText = "1 / 10";

                document.querySelector(".buttons").style.display =
                "block";

                document.getElementById("result").innerText = "";

                container.classList.remove("fade");

            }, 500);
        }

    </script>
</body>
</html>
