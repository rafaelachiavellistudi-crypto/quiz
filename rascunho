                yes: ["pop"],
                no: ["indie"]
            },

            {
                question: "Você gosta de guitarra distorcida?",
                yes: ["rock"],
                no: ["classic"]
            },

            {
                question: "Você gosta de músicas emocionantes?",
                yes: ["indie", "classic"],
                no: ["pop"]
            },

            {
                question: "Você gosta de playlists para relaxar?",
                yes: ["chill"],
                no: ["rock"]
            },

            {
