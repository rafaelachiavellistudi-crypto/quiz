
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz de gosto musical</title>

    <link rel="icon" type="image/png" href="image/favicon/favicon-32x32.png" sizes="32x32">

    <style>
        body {
            font-family: Arial, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            background-color: #f9f9f9;
        }

        .question-container {
            background-color: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            text-align: center;
            width: 400px;
            max-width: 90%;
        }

        h2 {
            min-height: 100px;
        }

        .buttons {
            margin-top: 20px;
        }

        button {
            margin: 0 10px;
            padding: 10px 20px;
            font-size: 16px;
            cursor: pointer;
            border: none;
            border-radius: 5px;
        }

        .yes {
            background-color: #4CAF50;
            color: white;
        }

        .no {
            background-color: #f44336;
            color: white;
        }

        #result {
            line-height: 1.5;
        }

        #counter {
            font-size: 14px;
            color: #777;
            text-align: right;
            margin-bottom: 10px;
            font-weight: bold;
        }

        #reset-btn {
            position: absolute;
            top: 20px;
            right: 20px;
            padding: 10px 15px;
            border: none;
            border-radius: 8px;
            background-color: #333;
            color: white;
            cursor: pointer;
            font-size: 14px;
            transition: 0.3s;
        }

        #reset-btn:hover {
            background-color: #555;
        }

        .fade {
            opacity: 0;
            transition: opacity 0.5s ease;
        }
    </style>
</head>
    <body>

    <div class="question-container">

        <div id="counter">1 / 10</div>

        <h2 id="question"></h2>

        <div class="buttons">
            <button class="yes" onclick="answer(true)">Sim</button>
            <button class="no" onclick="answer(false)">Não</button>
        </div>

        <div id="result"></div>

    </div>

    <button id="reset-btn" onclick="resetQuiz()">🔄 Reiniciar</button>

    <script>
        const styles = {
            pop: 0,
            rock: 0,
            indie: 0,
            chill: 0,
            classic: 0
        };

        const questions = [

            {
                question: "Você gosta de músicas agitadas e dançantes?",
                yes: ["pop"],
                no: ["classic"]
            },

            {
